<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>管理者ツール｜退職手続きコンシェルジュ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0F2F5C;--green:#059669;--green-light:#D1FAE5;--amber:#D97706;--amber-light:#FEF3C7;
  --gray-50:#F8FAFC;--gray-100:#F1F5F9;--gray-200:#E2E8F0;--gray-400:#94A3B8;
  --gray-600:#475569;--gray-800:#1E293B;--white:#fff;--radius:12px;
  --shadow:0 4px 24px rgba(15,47,92,.10);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans JP',sans-serif;color:var(--gray-800);background:var(--gray-50);line-height:1.75;font-size:15px;min-height:100vh;}

/* Gate */
#adminGate{position:fixed;inset:0;background:linear-gradient(135deg,#0F2F5C 0%,#1a3d6b 100%);display:flex;align-items:center;justify-content:center;z-index:9999;padding:24px;}
#adminGate.hidden{display:none;}
.gate-box{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:48px 40px;max-width:400px;width:100%;text-align:center;backdrop-filter:blur(10px);}
.gate-logo{font-size:15px;font-weight:900;color:rgba(255,255,255,.9);margin-bottom:8px;}
.gate-badge{font-size:11px;font-weight:700;background:rgba(255,200,0,.2);color:#FDE68A;padding:3px 12px;border-radius:100px;display:inline-block;margin-bottom:28px;}
.gate-title{font-size:20px;font-weight:900;color:var(--white);margin-bottom:8px;}
.gate-sub{font-size:13px;color:rgba(255,255,255,.55);margin-bottom:28px;}
.gate-input{width:100%;padding:13px 20px;border-radius:100px;border:2px solid rgba(255,255,255,.2);background:rgba(255,255,255,.1);color:var(--white);font-size:16px;text-align:center;outline:none;transition:border .2s;font-family:inherit;letter-spacing:.1em;}
.gate-input::placeholder{color:rgba(255,255,255,.3);letter-spacing:0;}
.gate-input:focus{border-color:rgba(255,255,255,.5);}
.gate-btn{margin-top:14px;width:100%;padding:13px;border-radius:100px;background:#059669;color:var(--white);font-size:15px;font-weight:700;border:none;cursor:pointer;font-family:inherit;transition:all .2s;}
.gate-btn:hover{background:#047857;}
.gate-err{margin-top:10px;font-size:13px;color:#FCA5A5;min-height:18px;}

/* App */
#adminApp{display:none;}
#adminApp.visible{display:block;}
.nav{background:var(--white);border-bottom:1px solid var(--gray-200);padding:0 24px;}
.nav-inner{display:flex;align-items:center;height:56px;max-width:800px;margin:0 auto;gap:12px;}
.nav-logo{font-size:15px;font-weight:900;color:var(--navy);}
.nav-badge{font-size:11px;font-weight:700;background:#FEF3C7;color:#D97706;padding:2px 10px;border-radius:100px;}
.nav-logout{margin-left:auto;font-size:12px;color:var(--gray-400);background:none;border:1px solid var(--gray-200);border-radius:100px;padding:5px 14px;cursor:pointer;font-family:inherit;}
.nav-logout:hover{color:var(--gray-800);border-color:var(--gray-400);}
.main{max-width:800px;margin:0 auto;padding:32px 24px 80px;}
.card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);padding:32px;margin-bottom:24px;}
.card-title{font-size:17px;font-weight:900;color:var(--navy);margin-bottom:20px;display:flex;align-items:center;gap:8px;}
.card-title::before{content:'';display:block;width:4px;height:20px;background:var(--green);border-radius:2px;}
.pw-row{display:flex;flex-direction:column;gap:16px;}
.pw-item{background:var(--gray-50);border-radius:10px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.pw-item.primary{background:var(--green-light);border:1.5px solid #6EE7B7;}
.pw-label{font-size:12px;font-weight:700;color:var(--gray-400);margin-bottom:4px;}
.pw-item.primary .pw-label{color:#065F46;}
.pw-value{font-size:28px;font-weight:900;color:var(--navy);letter-spacing:.15em;}
.pw-expires{font-size:13px;color:var(--gray-600);margin-top:4px;}
.pw-item.primary .pw-expires{color:#065F46;font-weight:700;}
.copy-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:100px;background:var(--green);color:var(--white);font-size:13px;font-weight:700;border:none;cursor:pointer;font-family:inherit;transition:all .2s;white-space:nowrap;}
.copy-btn:hover{background:#047857;}
.copy-btn.sec{background:var(--gray-200);color:var(--gray-800);}
.copy-btn.sec:hover{background:var(--gray-400);color:var(--white);}
.info-box{background:var(--amber-light);border:1px solid #FDE68A;border-radius:8px;padding:14px 18px;font-size:13px;color:var(--amber);margin-bottom:20px;line-height:1.7;}
.fg{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
.fg label{font-size:13px;font-weight:700;color:var(--gray-600);}
.fg input,.fg textarea{padding:10px 14px;border-radius:8px;border:1.5px solid var(--gray-200);font-size:14px;font-family:inherit;color:var(--gray-800);outline:none;transition:border .2s;background:var(--white);}
.fg input:focus,.fg textarea:focus{border-color:var(--navy);}
.fg textarea{resize:vertical;min-height:130px;}
.send-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:100px;background:var(--navy);color:var(--white);font-size:15px;font-weight:700;border:none;cursor:pointer;font-family:inherit;transition:all .2s;}
.send-btn:hover{background:#1E4D8C;transform:translateY(-1px);}
.algo-note{background:var(--gray-100);border-radius:8px;padding:14px 18px;font-size:12px;color:var(--gray-600);line-height:1.7;margin-top:16px;}
.algo-note code{background:var(--gray-200);padding:1px 6px;border-radius:4px;font-family:monospace;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{text-align:left;padding:8px 12px;color:var(--gray-600);border-bottom:2px solid var(--gray-200);}
td{padding:10px 12px;border-bottom:1px solid var(--gray-200);}
</style>
</head>
<body>

<!-- ADMIN GATE -->
<div id="adminGate">
  <div class="gate-box">
    <div class="gate-logo">🏛️ 退職手続きコンシェルジュ</div>
    <div class="gate-badge">管理者専用</div>
    <h1 class="gate-title">管理者パスワード</h1>
    <p class="gate-sub">管理者用パスワードを入力してください</p>
    <input type="password" id="adminPwInput" class="gate-input" placeholder="パスワード" autocomplete="current-password">
    <button class="gate-btn" onclick="checkAdminPw()">ログイン →</button>
    <div class="gate-err" id="adminGateErr"></div>
  </div>
</div>

<!-- ADMIN APP -->
<div id="adminApp">
<nav class="nav">
  <div class="nav-inner">
    <span class="nav-logo">🏛️ 退職手続きコンシェルジュ</span>
    <span class="nav-badge">管理者ツール</span>
    <button class="nav-logout" onclick="adminLogout()">ログアウト</button>
  </div>
</nav>

<main class="main">

  <div class="card">
    <div class="card-title">現在有効なパスワード</div>
    <div class="info-box">
      ⚠️ このページは管理者専用です。URLを外部に共有しないでください。パスワードは14日サイクルで自動更新されます。
    </div>
    <div class="pw-row" id="pwRow"><p style="color:var(--gray-400)">読み込み中...</p></div>
    <div class="algo-note">
      生成方式：<code>SHA-256(SALT + アンカー日付YYYYMMDD)</code> 先頭8文字を <code>XXXX-XXXX</code> 形式で表示。
      各パスワードは28日間有効。14日ごとに更新され、常に2つが重複有効です。
    </div>
  </div>

  <div class="card" id="emailjsSetupCard" style="border:2px solid #BFDBFE;background:#EFF6FF;">
    <div class="card-title" style="color:#1D4ED8">📬 EmailJS セットアップガイド（初回のみ）</div>
    <p style="font-size:13px;color:#1E3A8A;margin-bottom:16px">メール直接送信機能を使うには、EmailJS の無料アカウントが必要です。以下の手順で5〜10分で完了します。</p>
    <div style="display:flex;flex-direction:column;gap:12px;font-size:13px;color:#1E293B">
      <div style="background:white;border-radius:8px;padding:14px 16px;border:1px solid #BFDBFE">
        <strong style="color:#1D4ED8">STEP 1 — アカウント作成</strong><br>
        <a href="https://www.emailjs.com/" target="_blank" rel="noopener" style="color:#2563EB">emailjs.com</a> にアクセスし、無料アカウントを作成（月200通まで無料）。
      </div>
      <div style="background:white;border-radius:8px;padding:14px 16px;border:1px solid #BFDBFE">
        <strong style="color:#1D4ED8">STEP 2 — Gmail サービスを追加</strong><br>
        ダッシュボード → <strong>Email Services</strong> → <strong>Add New Service</strong> → <strong>Gmail</strong> を選択<br>
        → <strong>Connect Account</strong> をクリックし、<code style="background:#DBEAFE;padding:1px 5px;border-radius:3px">12312171016226a@gmail.com</code> でログイン・許可<br>
        → <strong>Service ID</strong>（例：<code style="background:#DBEAFE;padding:1px 5px;border-radius:3px">service_abc1234</code>）をメモ
      </div>
      <div style="background:white;border-radius:8px;padding:14px 16px;border:1px solid #BFDBFE">
        <strong style="color:#1D4ED8">STEP 3 — メールテンプレートを作成</strong><br>
        ダッシュボード → <strong>Email Templates</strong> → <strong>Create New Template</strong><br>
        以下のとおり設定してください：
        <table style="margin-top:8px;font-size:12px;width:100%">
          <tr><td style="padding:4px 8px;background:#EFF6FF;font-weight:700;width:120px">To Email</td><td style="padding:4px 8px"><code>&#123;&#123;to_email&#125;&#125;</code></td></tr>
          <tr><td style="padding:4px 8px;background:#EFF6FF;font-weight:700">CC</td><td style="padding:4px 8px"><code>itou@justy.co.jp</code>（固定で入力）</td></tr>
          <tr><td style="padding:4px 8px;background:#EFF6FF;font-weight:700">From Name</td><td style="padding:4px 8px">退職手続きコンシェルジュ</td></tr>
          <tr><td style="padding:4px 8px;background:#EFF6FF;font-weight:700">Subject</td><td style="padding:4px 8px"><code>&#123;&#123;subject&#125;&#125;</code></td></tr>
          <tr><td style="padding:4px 8px;background:#EFF6FF;font-weight:700">Content</td><td style="padding:4px 8px"><code>&#123;&#123;message&#125;&#125;</code>（Plain Text）</td></tr>
        </table>
        → <strong>Save</strong> して <strong>Template ID</strong>（例：<code style="background:#DBEAFE;padding:1px 5px;border-radius:3px">template_xyz9999</code>）をメモ
      </div>
      <div style="background:white;border-radius:8px;padding:14px 16px;border:1px solid #BFDBFE">
        <strong style="color:#1D4ED8">STEP 4 — Public Key を取得</strong><br>
        ダッシュボード右上アバター → <strong>Account</strong> → <strong>General</strong> → <strong>Public Key</strong> をメモ
      </div>
      <div style="background:#FEF9C3;border-radius:8px;padding:14px 16px;border:1px solid #FDE047">
        <strong style="color:#713F12">STEP 5 — admin.html の定数を書き換え</strong><br>
        このファイル（admin.html）をテキストエディタで開き、以下3行を実際の値に書き換えて保存・git push：<br>
        <code style="display:block;margin-top:8px;background:#FEF08A;padding:8px;border-radius:4px;font-size:11px;line-height:1.8">const EMAILJS_PUBLIC_KEY  = '取得したPublic Key';<br>const EMAILJS_SERVICE_ID  = '取得したService ID';<br>const EMAILJS_TEMPLATE_ID = '取得したTemplate ID';</code>
      </div>
    </div>
    <button onclick="document.getElementById('emailjsSetupCard').style.display='none'" style="margin-top:16px;font-size:12px;color:var(--gray-400);background:none;border:none;cursor:pointer;font-family:inherit">このガイドを閉じる ×</button>
  </div>

  <div class="card">
    <div class="card-title">パスワード通知メール</div>
    <div class="info-box" id="emailjsSetupNote" style="display:none;background:#EFF6FF;border-color:#BFDBFE;color:#1E40AF">
      ⚠️ EmailJS が未設定です。上のセットアップガイドを参照して3つの定数を設定してください。
    </div>
    <div id="emailSendStatus" style="display:none;border-radius:8px;padding:12px 16px;font-size:13px;margin-bottom:16px;font-weight:700;"></div>
    <div class="fg">
      <label>送信先メールアドレス</label>
      <input type="email" id="toEmail" placeholder="user@example.com">
    </div>
    <div class="fg">
      <label>メール件名</label>
      <input type="text" id="mailSubject" value="【退職手続きコンシェルジュ】書面作成ページのご案内">
    </div>
    <div class="fg">
      <label>メール本文（編集可能）</label>
      <textarea id="mailBody" rows="14"></textarea>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
      <button class="send-btn" id="sendEmailBtn" onclick="sendEmailDirect()">📧 メールを送信する</button>
      <button class="send-btn" onclick="openMailClient()" style="background:var(--gray-400);font-size:13px;padding:10px 20px">📨 メールアプリで開く</button>
    </div>
    <p style="font-size:12px;color:var(--gray-600);margin-top:10px;">送信元：退職手続きコンシェルジュ &lt;12312171016226a@gmail.com&gt;</p>
  </div>

  <div class="card">
    <div class="card-title">パスワード履歴（直近5サイクル）</div>
    <table>
      <thead>
        <tr>
          <th>アンカー日付</th>
          <th>パスワード</th>
          <th>有効期間</th>
          <th>状態</th>
        </tr>
      </thead>
      <tbody id="histBody"><tr><td colspan="4" style="color:var(--gray-400);padding:12px">読み込み中...</td></tr></tbody>
    </table>
  </div>

</main>
</div><!-- #adminApp -->

<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<script>
'use strict';
const ADMIN_HASH = 'd7d2fe5536b8c6962c7e447b30c0025f6b7805f3d5b49d3709bf6808fe97e3ce';
const SALT = 'TSCKeiyaku2026';
const SITE_URL = 'https://351justy.github.io/taisyoku/';

// ══════════════════════════════════════════════════════════════
// EmailJS 設定  ── 初回のみ以下の手順で設定してください ──
//
// 【STEP 1】 https://www.emailjs.com/ でアカウント作成（無料）
//
// 【STEP 2】 Email Services タブ → "Add New Service"
//            → Gmail を選択 → "Connect Account" で
//              12312171016226a@gmail.com でログイン・許可
//            → Service ID をメモ（例: service_xxxxxxx）
//
// 【STEP 3】 Email Templates タブ → "Create New Template"
//            テンプレート設定：
//              To Email  : {{to_email}}
//              CC        : itou@justy.co.jp          ← CCを固定で設定
//              From Name : 退職手続きコンシェルジュ
//              Subject   : {{subject}}
//              Body(Text): {{message}}
//            → "Save" して Template ID をメモ（例: template_xxxxxxx）
//
// 【STEP 4】 Account → API Keys → Public Key をメモ
//
// 【STEP 5】 下記3定数を実際の値に書き換える
// ══════════════════════════════════════════════════════════════
const EMAILJS_PUBLIC_KEY  = 'YOUR_PUBLIC_KEY';   // ← Public Key に書き換え
const EMAILJS_SERVICE_ID  = 'YOUR_SERVICE_ID';   // ← Service ID に書き換え
const EMAILJS_TEMPLATE_ID = 'YOUR_TEMPLATE_ID';  // ← Template ID に書き換え
// ══════════════════════════════════════════════════════════════

async function sha256(s){
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function checkAdminPw(){
  const val = document.getElementById('adminPwInput').value.trim();
  if(!val){ document.getElementById('adminGateErr').textContent='パスワードを入力してください'; return; }
  const h = await sha256(val);
  if(h === ADMIN_HASH){
    document.getElementById('adminGate').classList.add('hidden');
    document.getElementById('adminApp').classList.add('visible');
    sessionStorage.setItem('tsc_admin','1');
    initAdmin();
  } else {
    document.getElementById('adminGateErr').textContent='パスワードが正しくありません';
    document.getElementById('adminPwInput').value='';
  }
}
document.getElementById('adminPwInput').addEventListener('keydown', e=>{ if(e.key==='Enter') checkAdminPw(); });
function adminLogout(){ sessionStorage.removeItem('tsc_admin'); location.reload(); }
if(sessionStorage.getItem('tsc_admin')==='1'){
  document.getElementById('adminGate').classList.add('hidden');
  document.getElementById('adminApp').classList.add('visible');
}

async function derivePassword(anchorEpochDays){
  const d = new Date(anchorEpochDays * 86400000);
  const ymd = d.getUTCFullYear()
    + String(d.getUTCMonth()+1).padStart(2,'0')
    + String(d.getUTCDate()).padStart(2,'0');
  const h = await sha256(SALT + ymd);
  const raw = h.substring(0,8).toUpperCase();
  return raw.substring(0,4)+'-'+raw.substring(4,8);
}
function epochToYMD(days){
  const d = new Date(days*86400000);
  return `${d.getUTCFullYear()}/${String(d.getUTCMonth()+1).padStart(2,'0')}/${String(d.getUTCDate()).padStart(2,'0')}`;
}
function epochToJp(days){
  const d = new Date(days*86400000);
  return `${d.getUTCFullYear()}年${d.getUTCMonth()+1}月${d.getUTCDate()}日`;
}

async function initAdmin(){
  const todayDays = Math.floor(Date.now()/86400000);
  const offset = todayDays % 14;
  const a1 = todayDays - offset;
  const a2 = a1 - 14;
  const daysLeft1 = 28 - offset;
  const daysLeft2 = 14 - offset;
  const pw1 = await derivePassword(a1);
  const pw2 = await derivePassword(a2);

  // Password cards
  let html = `
    <div class="pw-item primary">
      <div>
        <div class="pw-label">🔑 プライマリ（有効期間が長い方）</div>
        <div class="pw-value">${pw1}</div>
        <div class="pw-expires">残り ${daysLeft1} 日（アンカー：${epochToJp(a1)}）</div>
      </div>
      <button class="copy-btn" onclick="copyText('${pw1}',this)">📋 コピー</button>
    </div>`;
  if(daysLeft2 > 0){
    html += `
    <div class="pw-item">
      <div>
        <div class="pw-label">🔑 セカンダリ（まだ有効）</div>
        <div class="pw-value" style="font-size:22px">${pw2}</div>
        <div class="pw-expires">残り ${daysLeft2} 日（アンカー：${epochToJp(a2)}）</div>
      </div>
      <button class="copy-btn sec" onclick="copyText('${pw2}',this)">📋 コピー</button>
    </div>`;
  } else {
    html += `<div class="pw-item"><div style="color:var(--gray-400);font-size:13px">セカンダリは期限切れです（サイクルの後半14日間は1パスワードのみ有効）</div></div>`;
  }
  document.getElementById('pwRow').innerHTML = html;

  // Mail body
  document.getElementById('mailBody').value =
`この度は退職手続きコンシェルジュをご利用いただきありがとうございます。

お支払いが確認できましたので、書面作成ページへのアクセスパスワードをお知らせします。

━━━━━━━━━━━━━━━━━━━━━━━━
書面作成ページURL：
${SITE_URL}app.html

パスワード：${pw1}
有効期限：本日より${daysLeft1}日間
━━━━━━━━━━━━━━━━━━━━━━━━

【ご利用手順】
1. 上記URLにアクセスしてください
2. パスワードを入力してログインしてください
3. ステップ1「基本情報」に会社名・送付日などを入力してください
4. ステップ2「書面生成」から必要な書面をPDFで生成してください
5. 印刷後、自署欄に署名・日付を手書きで記入してください
6. 配達証明郵便で会社宛に送付してください

ご不明点がございましたら、このメールへの返信にてお問い合わせください。

退職手続きコンシェルジュ`;

  // History table
  const tbody = document.getElementById('histBody');
  const rows = [];
  for(let i=-1; i<=3; i++){
    const anchor = a1 + i*14;
    const pw = await derivePassword(anchor);
    const from = epochToYMD(anchor);
    const to = epochToYMD(anchor+27);
    const today = todayDays;
    let status;
    if(anchor > today) status = '<span style="color:var(--gray-400)">未来</span>';
    else if(anchor+28 <= today) status = '<span style="color:var(--gray-400)">期限切れ</span>';
    else if(anchor === a1) status = '<span style="color:var(--green);font-weight:700">✓ プライマリ</span>';
    else status = '<span style="color:#D97706;font-weight:700">✓ セカンダリ</span>';
    rows.push(`<tr>
      <td>${from}</td>
      <td style="font-weight:700;letter-spacing:.1em">${pw}</td>
      <td style="font-size:12px;color:var(--gray-600)">${from} 〜 ${to}</td>
      <td>${status}</td>
    </tr>`);
  }
  tbody.innerHTML = rows.join('');
}

function copyText(text,btn){
  navigator.clipboard.writeText(text).then(()=>{
    const orig=btn.innerHTML;btn.innerHTML='✅ コピーしました';
    setTimeout(()=>{ btn.innerHTML=orig; },2000);
  }).catch(()=>{ alert('コピーできません。手動でコピーしてください:\n'+text); });
}

function showEmailStatus(msg, type){
  const el = document.getElementById('emailSendStatus');
  el.style.display = 'block';
  el.textContent = msg;
  if(type === 'ok')  { el.style.background='#D1FAE5'; el.style.color='#065F46'; }
  if(type === 'err') { el.style.background='#FEE2E2'; el.style.color='#991B1B'; }
  if(type === 'ing') { el.style.background='#EFF6FF'; el.style.color='#1E40AF'; }
}

async function sendEmailDirect(){
  const to   = document.getElementById('toEmail').value.trim();
  const subj = document.getElementById('mailSubject').value.trim();
  const body = document.getElementById('mailBody').value.trim();
  if(!to)  { alert('送信先メールアドレスを入力してください。'); return; }
  if(!body){ alert('メール本文が空です。'); return; }

  if(EMAILJS_PUBLIC_KEY === 'YOUR_PUBLIC_KEY'){
    document.getElementById('emailjsSetupNote').style.display = 'block';
    showEmailStatus('⚠️ EmailJS が未設定です。まず設定を完了してください。', 'err');
    return;
  }

  const btn = document.getElementById('sendEmailBtn');
  btn.disabled = true;
  btn.textContent = '⌛ 送信中...';
  showEmailStatus('⌛ 送信中...', 'ing');

  try {
    emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });
    await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
      to_email:  to,
      subject:   subj,
      message:   body,
      from_name: '退職手続きコンシェルジュ',
      // CC は EmailJS テンプレート側で itou@justy.co.jp を固定設定済み
    });
    showEmailStatus('✅ 送信完了！　宛先：' + to + '　CC：itou@justy.co.jp', 'ok');
    btn.textContent = '✅ 送信完了';
    setTimeout(()=>{ btn.disabled=false; btn.textContent='📧 メールを送信する'; }, 4000);
  } catch(e) {
    console.error('EmailJS error:', e);
    showEmailStatus('❌ 送信失敗：' + (e.text || e.message || JSON.stringify(e)), 'err');
    btn.disabled = false;
    btn.textContent = '📧 メールを送信する';
  }
}

function openMailClient(){
  const to = document.getElementById('toEmail').value.trim();
  if(!to){ alert('送信先メールアドレスを入力してください。'); return; }
  const subj = encodeURIComponent(document.getElementById('mailSubject').value);
  const body = encodeURIComponent(document.getElementById('mailBody').value);
  window.location.href = `mailto:${to}?subject=${subj}&body=${body}`;
}

if(sessionStorage.getItem('tsc_admin')==='1'){
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', initAdmin);
  else initAdmin();
}
</script>
</body>
</html>